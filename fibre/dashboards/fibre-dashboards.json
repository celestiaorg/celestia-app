{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Operational Overview",
      "type": "row"
    },
    {
      "title": "Upload Success Rate",
      "type": "stat",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.95 },
            { "color": "green", "value": 0.99 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "sum(rate(fibre_client_upload_duration_seconds_count{success=\"true\"}[$__rate_interval])) / sum(rate(fibre_client_upload_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "success %"
        }
      ]
    },
    {
      "title": "Download Success Rate",
      "type": "stat",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.95 },
            { "color": "green", "value": 0.99 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "sum(rate(fibre_client_download_duration_seconds_count{success=\"true\"}[$__rate_interval])) / sum(rate(fibre_client_download_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "success %"
        }
      ]
    },
    {
      "title": "Uploads In-Flight",
      "type": "stat",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 50 },
            { "color": "red", "value": 100 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "expr": "sum(fibre_client_upload_in_flight)", "legendFormat": "uploads" }
      ]
    },
    {
      "title": "Downloads In-Flight",
      "type": "stat",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 50 },
            { "color": "red", "value": 100 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "expr": "sum(fibre_client_download_in_flight)", "legendFormat": "downloads" }
      ]
    },
    {
      "title": "Success Rates Over Time",
      "type": "timeseries",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(fibre_client_upload_duration_seconds_count{success=\"true\"}[$__rate_interval])) / sum(rate(fibre_client_upload_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "Upload"
        },
        {
          "expr": "sum(rate(fibre_client_download_duration_seconds_count{success=\"true\"}[$__rate_interval])) / sum(rate(fibre_client_download_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "Download"
        }
      ]
    },
    {
      "title": "Latency p99",
      "type": "timeseries",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(fibre_client_upload_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "Upload p99"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(fibre_client_download_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "Download p99"
        }
      ]
    },
    {
      "title": "In-Flight Over Time",
      "type": "timeseries",
      "id": 7,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "sum(fibre_client_upload_in_flight)", "legendFormat": "Client Uploads" },
        { "expr": "sum(fibre_client_download_in_flight)", "legendFormat": "Client Downloads" },
        { "expr": "sum(fibre_server_upload_shard_in_flight)", "legendFormat": "Server UploadShard" },
        { "expr": "sum(fibre_server_download_shard_in_flight)", "legendFormat": "Server DownloadShard" }
      ]
    },
    {
      "title": "Throughput",
      "type": "timeseries",
      "id": 8,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "sum(rate(fibre_client_upload_bytes_total[$__rate_interval]))", "legendFormat": "Client Upload" },
        { "expr": "sum(rate(fibre_client_download_bytes_total[$__rate_interval]))", "legendFormat": "Client Download" },
        { "expr": "sum(rate(fibre_server_upload_shard_bytes_total[$__rate_interval]))", "legendFormat": "Server UploadShard" },
        { "expr": "sum(rate(fibre_server_download_shard_bytes_total[$__rate_interval]))", "legendFormat": "Server DownloadShard" }
      ]
    },
    {
      "title": "Total Upload Throughput (Data vs Network)",
      "type": "timeseries",
      "id": 9,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "sum(rate(fibre_client_upload_data_bytes_total[$__rate_interval]))", "legendFormat": "Data (without coding overhead)" },
        { "expr": "sum(rate(fibre_client_upload_network_bytes_total[$__rate_interval]))", "legendFormat": "Network (with coding overhead)" },
        { "expr": "sum(rate(fibre_client_upload_bytes_total[$__rate_interval]))", "legendFormat": "Upload (original rows, with padding)" }
      ]
    },

