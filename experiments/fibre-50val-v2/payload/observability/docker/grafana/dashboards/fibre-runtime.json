{
  "title": "Fibre Go Runtime",
  "uid": "fibre-go-runtime",
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Goroutines & Processors",
      "type": "row"
    },
    {
      "title": "Goroutine Count",
      "type": "timeseries",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "go_goroutine_count{service_instance_id=~\"$instance\"}",
          "legendFormat": "{{ service_instance_id }}"
        }
      ]
    },
    {
      "title": "GOMAXPROCS",
      "type": "timeseries",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "go_processor_limit{service_instance_id=~\"$instance\"}",
          "legendFormat": "{{ service_instance_id }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200,
      "title": "Memory",
      "type": "row"
    },
    {
      "title": "Memory Used",
      "type": "timeseries",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "normal" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "go_memory_used_bytes{service_instance_id=~\"$instance\", go_memory_type=\"other\"}",
          "legendFormat": "{{ service_instance_id }} heap"
        },
        {
          "expr": "go_memory_used_bytes{service_instance_id=~\"$instance\", go_memory_type=\"stack\"}",
          "legendFormat": "{{ service_instance_id }} stack"
        }
      ]
    },
    {
      "title": "Memory Limit vs GC Goal",
      "type": "timeseries",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "pointSize": 5, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "go_memory_limit_bytes{service_instance_id=~\"$instance\"}",
          "legendFormat": "{{ service_instance_id }} GOMEMLIMIT"
        },
        {
          "expr": "go_memory_gc_goal_bytes{service_instance_id=~\"$instance\"}",
          "legendFormat": "{{ service_instance_id }} GC goal"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "title": "Allocations",
      "type": "row"
    },
    {
      "title": "Allocation Rate",
      "type": "timeseries",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(go_memory_allocated_bytes_total{service_instance_id=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{ service_instance_id }}"
        }
      ]
    },
    {
      "title": "Object Allocation Rate",
      "type": "timeseries",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(go_memory_allocations_total{service_instance_id=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{ service_instance_id }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 400,
      "title": "GC Configuration",
      "type": "row"
    },
    {
      "title": "GOGC (%)",
      "type": "timeseries",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "pointSize": 5, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "go_config_gogc_percent{service_instance_id=~\"$instance\"}",
          "legendFormat": "{{ service_instance_id }}"
        }
      ]
    },
    {
      "title": "Memory Overview",
      "type": "stat",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 536870912 },
            { "color": "red", "value": 1073741824 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "orientation": "horizontal" },
      "targets": [
        {
          "expr": "sum by (service_instance_id) (go_memory_used_bytes{service_instance_id=~\"$instance\"})",
          "legendFormat": "{{ service_instance_id }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["fibre", "runtime", "celestia"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(go_goroutine_count, service_instance_id)",
        "query": {
          "query": "label_values(go_goroutine_count, service_instance_id)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "version": 1
}
